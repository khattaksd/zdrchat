#!/bin/bash
# =============================================================================
# POST-MERGE HOOK — Auto-sync staging with main
# =============================================================================
#
# This hook runs AFTER every successful merge or pull (git merge / git pull).
#
# Purpose:
#   When you merge staging → main (locally or via GitHub PR + local pull),
#   main gets new commits that staging doesn't have. Over time this causes
#   divergence. This hook automatically merges those commits back into
#   staging so both branches stay in sync.
#
# How it works:
#   1. Only fires when the merge target is "main"
#   2. Fetches the latest remote state
#   3. Checks if main has commits that staging is missing
#   4. If yes: switches to staging, merges main in, pushes to origin
#   5. Returns to your original branch
#
# After this hook fires, your workflow is:
#   git checkout main
#   git merge staging         # or git pull after a PR merge
#   git push origin main
#   # hook auto-syncs staging ↑
#
# Edge cases handled:
#   - Only runs on main → no effect on staging or feature branches
#   - Gracefully skips if staging is already up to date
#   - Silent if origin is unreachable (offline)
#   - Safe to delete/reinstall (it's in .git/hooks/, not tracked by git)
# =============================================================================

# Save the branch we started on so we can return later
ORIGINAL_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

# --- Only act when the merge target is "main" ---
# If you're working in staging or any other branch, this hook is a no-op.
if [ "$ORIGINAL_BRANCH" != "main" ]; then
    exit 0
fi

# --- Suppress all errors from here onward ---
# We don't want a network failure to crash git for the user.
# The hook is a convenience — if anything fails, silently skip.
set +e

# --- Fetch latest remote state ---
# We need to know what origin/staging and origin/main look like.
git fetch origin 2>/dev/null

# --- Check if staging is behind main ---
# rev-list --count counts commits reachable from one ref but not another.
# origin/main..origin/staging  =  commits in staging but not in main  (staging is ahead)
# origin/staging..origin/main  =  commits in main but not in staging  (staging is behind)
COMMITS_BEHIND=$(git rev-list --count origin/staging..origin/main 2>/dev/null || echo "0")
COMMITS_AHEAD=$(git rev-list --count origin/main..origin/staging 2>/dev/null || echo "0")

# --- Only proceed if main has commits that staging is missing ---
if [ "$COMMITS_BEHIND" -eq 0 ]; then
    # Nothing to sync — staging is already at or ahead of main
    exit 0
fi

# --- Notify the user what's happening ---
echo ""
echo "🔄 post-merge hook: Syncing staging with main..."
echo "   staging is $COMMITS_BEHIND commit(s) behind main"
echo "   staging is $COMMITS_AHEAD commit(s) ahead of main"

# --- Switch to staging and merge main into it ---
# Save any uncommitted changes with stash (just in case)
git stash push --quiet --include-untracked -m "post-merge-auto-stash" 2>/dev/null

# Checkout staging (create local tracking branch if it doesn't exist)
git checkout staging 2>/dev/null || git checkout -b staging origin/staging 2>/dev/null

# Merge main's latest into staging
# --no-edit: use the default merge message, don't prompt
# --no-ff:   keep a merge commit for traceability
git merge origin/main --no-edit 2>&1 | sed 's/^/   /'

# Push the synced staging branch back to origin
git push origin staging 2>&1 | sed 's/^/   /'

# --- Return to where we started ---
git checkout "$ORIGINAL_BRANCH" 2>/dev/null

# Restore stashed changes if any
git stash pop --quiet 2>/dev/null

echo "✅ post-merge hook: staging is now in sync with main ($COMMITS_BEHIND commit(s) merged)"
echo ""